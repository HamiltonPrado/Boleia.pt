{
  "info": {
    "name": "Boleia API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost/Boleia/backend" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user@example.com\", \"password\": \"password123\"}"
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user@example.com\", \"password\": \"password123\", \"full_name\": \"João Silva\", \"phone\": \"912345678\", \"role\": \"PASSENGER\"}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout.php"
          }
        },
        {
          "name": "Me (sessão atual)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me.php"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Listar reservas (passageiro)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/bookings/index.php"
          }
        },
        {
          "name": "Criar reserva",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bookings/index.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"occurrence_id\": \"uuid\", \"pickup_stop_id\": \"uuid\", \"dropoff_stop_id\": \"uuid\", \"seats_booked\": 1, \"note_to_driver\": null}"
            }
          }
        },
        {
          "name": "Pesquisar rotas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/bookings/search.php?date=2026-05-01&originLat=38.7169&originLng=-9.1395&destLat=38.7500&destLng=-9.1500",
              "query": [
                { "key": "date", "value": "2026-05-01" },
                { "key": "originLat", "value": "38.7169" },
                { "key": "originLng", "value": "-9.1395" },
                { "key": "destLat", "value": "38.7500" },
                { "key": "destLng", "value": "-9.1500" }
              ]
            }
          }
        },
        {
          "name": "Cancelar reserva (passageiro)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/bookings/cancel.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            }
          }
        },
        {
          "name": "Reservas do motorista",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/bookings/driver_bookings.php?status=PENDING",
              "query": [{ "key": "status", "value": "PENDING", "description": "PENDING | CONFIRMED | COMPLETED" }]
            }
          }
        },
        {
          "name": "Confirmar / recusar reserva (motorista)",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/bookings/update_status.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"CONFIRMED\"}"
            }
          }
        },
        {
          "name": "Concluir / no-show (motorista)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/bookings/complete.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"COMPLETED\"}"
            }
          }
        },
        {
          "name": "Cancelar reserva confirmada (motorista)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/bookings/driver_cancel.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            }
          }
        }
      ]
    },
    {
      "name": "Routes",
      "item": [
        {
          "name": "Listar rotas do motorista",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/routes/index.php"
          }
        },
        {
          "name": "Criar rota",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/routes/index.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"total_seats\": 4, \"price_per_seat\": 5.00, \"depart_time\": \"08:00:00\", \"recurrence\": {\"days_of_week\": [1,2,3,4,5]}, \"valid_from\": \"2026-05-01\", \"valid_until\": \"2026-12-31\", \"notes\": null, \"stops\": [{\"stop_order\": 1, \"label\": \"Origem\", \"address\": \"Rua A\", \"lat\": 38.71, \"lng\": -9.13, \"is_optional\": false}, {\"stop_order\": 2, \"label\": \"Destino\", \"address\": \"Rua B\", \"lat\": 38.75, \"lng\": -9.15, \"is_optional\": false}]}"
            }
          }
        },
        {
          "name": "Detalhe de rota",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/routes/detail.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            }
          }
        },
        {
          "name": "Atualizar estado da rota",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/routes/detail.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"PAUSED\"}"
            }
          }
        },
        {
          "name": "Apagar rota",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/routes/detail.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            }
          }
        },
        {
          "name": "Gerar ocorrências (30 dias)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/routes/generate.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            }
          }
        },
        {
          "name": "Estatísticas do motorista",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/routes/stats.php"
          }
        },
        {
          "name": "Estatísticas públicas",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/routes/public_stats.php"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Passageiro avalia motorista",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/reviews/create.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"booking_id\": \"uuid\", \"rating\": 5, \"comment\": \"Excelente\", \"tags\": null}"
            }
          }
        },
        {
          "name": "Motorista avalia passageiro",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/reviews/create_driver.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"booking_id\": \"uuid\", \"rating\": 4, \"comment\": null, \"tags\": null}"
            }
          }
        },
        {
          "name": "Avaliações recebidas",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/reviews/received.php"
          }
        },
        {
          "name": "Reservas avaliáveis (passageiro)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/reviews/reviewable.php"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Perfil público do motorista",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/profile.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            }
          }
        },
        {
          "name": "Atualizar perfil próprio",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/profile.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"full_name\": \"João Silva\", \"phone\": \"912345678\", \"avatar_url\": null}"
            }
          }
        },
        {
          "name": "Info do carro",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/car.php"
          }
        },
        {
          "name": "Atualizar carro",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/car.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"car_make\": \"Toyota\", \"car_model\": \"Corolla\", \"car_year\": 2020, \"car_plate\": \"AA-00-BB\"}"
            }
          }
        },
        {
          "name": "Listar documentos",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/documents.php"
          }
        },
        {
          "name": "Submeter documento",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users/documents.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"type\": \"LICENSE\", \"file_url\": \"https://example.com/doc.pdf\"}"
            }
          }
        },
        {
          "name": "Alterar password",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/password.php",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"current_password\": \"old123\", \"new_password\": \"new123456\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Estatísticas",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/stats.php"
          }
        },
        {
          "name": "Listar utilizadores",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/users.php?page=1&limit=20&search=",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Motoristas pendentes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/drivers_pending.php"
          }
        },
        {
          "name": "Documentos pendentes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/documents.php"
          }
        },
        {
          "name": "Rever documento",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/admin/review_document.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"action\": \"approve\", \"rejection_note\": null}"
            }
          }
        },
        {
          "name": "Rever motorista",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/admin/review_driver.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"action\": \"approve\"}"
            }
          }
        },
        {
          "name": "Ativar / suspender utilizador",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/admin/update_user_status.php?id=uuid",
              "query": [{ "key": "id", "value": "uuid" }]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"SUSPENDED\"}"
            }
          }
        },
        {
          "name": "Atividade (gráfico)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/activity.php"
          }
        }
      ]
    }
  ]
}
